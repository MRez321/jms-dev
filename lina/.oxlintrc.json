{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "env": {
    "browser": true,
    "node": true,
    "es6": true
  },
  "globals": {
    "_": "readonly",
    "$xss": "readonly"
  },
  "ignorePatterns": ["build/*.js", "node_modules", "public", "dist", "lina", "src/assets"],
  "categories": {
    "correctness": "off",
    "suspicious": "off",
    "pedantic": "off",
    "perf": "off",
    "style": "off",
    "restriction": "off"
  },
  "rules": {
    "curly": ["error", "multi-line"],
    "eqeqeq": [
      "error",
      "always",
      {
        "null": "ignore"
      }
    ],
    "no-console": "off",
    "no-debugger": "warn",
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-new-func": "error",
    "no-var": "warn",
    "prefer-const": "warn"
  }
}
