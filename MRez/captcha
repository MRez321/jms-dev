from settings.models import Setting
from django.core.cache import cache

# Clear cache
cache.clear()

# Verify setting exists
setting = Setting.objects.filter(name='LOGIN_CAPTCHA_ENABLED').first()
if setting:
    print(f"Setting found: {setting.name} = {setting.value}")
    # Force update it again
    setting.value = 'false'
    setting.save()
    print("Updated to false")
else:
    print("Setting not found - creating it")
    Setting.objects.create(name='LOGIN_CAPTCHA_ENABLED', value='false', category='security')

exit()
