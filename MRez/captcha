from settings.models import Setting

# Check what settings exist
settings_list = Setting.objects.filter(name__icontains='captcha')
for s in settings_list:
    print(f"{s.name} = {s.value}")

# Create or update the correct setting
setting, created = Setting.objects.update_or_create(
    name='SECURITY_LOGIN_CAPTCHA_ENABLED',
    defaults={'value': 'false', 'category': 'security'}
)
print(f"Setting {'created' if created else 'updated'}: {setting.name} = {setting.value}")

# Also set the old one to be safe
Setting.objects.update_or_create(
    name='LOGIN_CAPTCHA_ENABLED',
    defaults={'value': 'false', 'category': 'security'}
)

