# Default to LF for all text files
* text=auto eol=lf

# Shell scripts
*.sh text eol=lf

# Python
*.py text eol=lf

# Docker
Dockerfile text eol=lf
Dockerfile* text eol=lf

# YAML
*.yml text eol=lf
*.yaml text eol=lf

# JavaScript / TypeScript
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf

# JSON
*.json text eol=lf

# HTML / CSS
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf

# Markdown
*.md text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary